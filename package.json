{
  "name": "kings-and-pigs-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "2D platformer Kings and Pigs built with Phaser 3 and packaged as a React Native + Expo app.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "game:dev": "pnpm --filter game dev",
